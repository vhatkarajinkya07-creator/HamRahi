# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://127.0.0.1:5173

# Database
MONGO_URI=your_mongodb_connection_string_here

# Auth cookies / JWT
# Use a long random string. Example command:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_long_random_jwt_secret_here

# Google Login
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Gemini AI itinerary / recommendations
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# Unsplash destination images
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# OpenStreetMap / Nominatim
# Keep this at 1000ms or higher for the public Nominatim service.
NOMINATIM_MIN_INTERVAL_MS=1200
NOMINATIM_CACHE_TTL_MS=3600000

# Email verification sender
# For Gmail, use an app password, not your normal Gmail password.
EMAIL_USER=your_email_address_here
EMAIL_PASS=your_email_app_password_here
