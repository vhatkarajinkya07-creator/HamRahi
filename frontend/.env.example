# ─── Backend API ─────────────────────────────────────────────────────────────
# URL of your backend server. Leave blank to use the Vite proxy (/api → localhost:5000)
# In production, set this to your deployed backend URL e.g. https://api.hamrahi.com
VITE_API_URL=http://localhost:5000/api

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Same Client ID used in backend. Required for the Google Login button.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Leave blank to disable Google login button silently.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
