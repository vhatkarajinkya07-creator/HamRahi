# Left unset by default. src/services/api.js falls back to baseURL "/api",
# and Vite's dev proxy (see vite.config.js) forwards "/api" requests to the
# backend (http://localhost:3000 by default) — so in normal local dev you
# don't need to set this at all, and CORS never enters the picture.
#
# Only set VITE_API_URL if you're pointing at a backend that ISN'T proxied
# (a separately hosted/deployed backend, or a different local port). If you
# do set it, it must match the backend's actual PORT (see backend/.env),
# and the backend's CORS middleware (app.js) must allow this origin via
# CLIENT_URL.
# VITE_API_URL=http://localhost:3000/api

# Google OAuth Client ID used by the frontend's GoogleOAuthProvider and the
# "Continue with Google" button (see src/components/GoogleAuthButton).
# This MUST be the same value as GOOGLE_CLIENT_ID in backend/.env — Google
# Client IDs are public identifiers, not secrets, so this is safe to expose
# in frontend code. Fill in your own value below.
VITE_GOOGLE_CLIENT_ID=

# (Optional) Cesium Ion Access Token for rendering 3D World Terrain in the 3D globe homepage.
# If left empty, the application falls back to a standard 3D ellipsoid globe without crashing.
VITE_CESIUM_ACCESS_TOKEN=
